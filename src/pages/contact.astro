---
import Base from '../layouts/Base.astro';
---

<Base title="Contact" description="Get in touch with Integraw for e-commerce development, PrestaShop, and WordPress projects. Free consultation available.">

  <div class="max-w-6xl mx-auto px-6 py-14 grid md:grid-cols-2 gap-16">

    <!-- Left: info -->
    <div>
      <h1 class="text-4xl md:text-5xl font-bold text-brand-900 mb-4">Let's build something</h1>
      <p class="text-gray-500 text-xl leading-relaxed mb-10">
        Tell us about your project and we'll get back to you with a free quote within 24 hours.
      </p>

      <div class="space-y-6">
        {[
          { icon: '📧', label: 'Email', value: 'hello@integraw.in', href: 'mailto:hello@integraw.in' },
          { icon: '💬', label: 'WhatsApp', value: '+91 98765 43210', href: 'https://wa.me/919876543210' },
          { icon: '📍', label: 'Location', value: 'Kozhikode, Kerala, India', href: null },
        ].map(c => (
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-brand-50 rounded-xl flex items-center justify-center text-lg flex-shrink-0">
              {c.icon}
            </div>
            <div>
              <p class="text-xs text-gray-400 uppercase tracking-wide">{c.label}</p>
              {c.href ? (
                <a href={c.href} class="font-medium text-brand-600 hover:underline">{c.value}</a>
              ) : (
                <p class="font-medium text-gray-700">{c.value}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: form -->
    <div class="bg-white border border-gray-100 rounded-2xl p-8 shadow-sm">
      <h2 class="text-xl font-bold text-brand-900 mb-6">Send us a message</h2>

      <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-5">

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1.5">Name</label>
            <input type="text" id="name" name="name" required placeholder="Your name"
                   class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent transition" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
            <input type="email" id="email" name="email" required placeholder="you@example.com"
                   class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent transition" />
          </div>
        </div>

        <div>
          <label for="service" class="block text-sm font-medium text-gray-700 mb-1.5">Service needed</label>
          <select id="service" name="service"
                  class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 transition">
            <option value="">Select a service...</option>
            <option>PrestaShop Development</option>
            <option>WordPress / WooCommerce</option>
            <option>Store Migration</option>
            <option>Performance & SEO</option>
            <option>Maintenance & Support</option>
            <option>Other</option>
          </select>
        </div>

        <div>
          <label for="budget" class="block text-sm font-medium text-gray-700 mb-1.5">Budget range</label>
          <select id="budget" name="budget"
                  class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 transition">
            <option value="">Select a range...</option>
            <option>Under ₹50,000</option>
            <option>₹50,000 – ₹1,50,000</option>
            <option>₹1,50,000 – ₹5,00,000</option>
            <option>₹5,00,000+</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">Project details</label>
          <textarea id="message" name="message" rows="4" required
                    placeholder="Tell us about your project, goals, timeline..."
                    class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 transition resize-none"></textarea>
        </div>

        <button type="submit"
                class="w-full bg-brand-600 hover:bg-brand-800 text-white font-semibold py-3 rounded-xl transition-colors">
          Send message →
        </button>

        <p class="text-xs text-gray-400 text-center">We reply within 24 hours on business days.</p>
      </form>
    </div>

  </div>

</Base>
