---
export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Integraw — E-commerce development, PrestaShop & WordPress experts based in Kerala, India.',
  image = '/og-default.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalURL} />

  <!-- SEO -->
  <title>{title} | Integraw</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:title"       content={`${title} | Integraw`} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={new URL(image, Astro.site)} />

  <!-- Twitter -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={`${title} | Integraw`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={new URL(image, Astro.site)} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>

<body class="bg-white text-gray-900 antialiased">

  <!-- NAV -->
  <header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-100">
    <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center">
          <span class="text-white font-bold text-sm">IW</span>
        </div>
        <span class="font-bold text-brand-600 text-lg tracking-tight">integraw</span>
      </a>

      <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
        <li><a href="/services" class="hover:text-brand-600 transition-colors">Services</a></li>
        <li><a href="/portfolio" class="hover:text-brand-600 transition-colors">Portfolio</a></li>
        <li><a href="/blog" class="hover:text-brand-600 transition-colors">Blog</a></li>
        <li><a href="/about" class="hover:text-brand-600 transition-colors">About</a></li>
        <li>
          <a href="/contact"
             class="bg-brand-600 text-white px-4 py-2 rounded-lg hover:bg-brand-800 transition-colors">
            Get a quote
          </a>
        </li>
      </ul>

      <!-- Mobile menu button -->
      <button id="menu-btn" class="md:hidden p-2 text-gray-600" aria-label="Toggle menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </nav>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white px-6 pb-4">
      <ul class="flex flex-col gap-3 pt-3 text-sm font-medium text-gray-600">
        <li><a href="/services"  class="block py-1 hover:text-brand-600">Services</a></li>
        <li><a href="/portfolio" class="block py-1 hover:text-brand-600">Portfolio</a></li>
        <li><a href="/blog"      class="block py-1 hover:text-brand-600">Blog</a></li>
        <li><a href="/about"     class="block py-1 hover:text-brand-600">About</a></li>
        <li><a href="/contact"   class="block mt-1 bg-brand-600 text-white px-4 py-2 rounded-lg text-center">Get a quote</a></li>
      </ul>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="bg-brand-900 text-white mt-24">
    <div class="max-w-6xl mx-auto px-6 py-14 grid md:grid-cols-4 gap-10">
      <div class="md:col-span-2">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-9 h-9 rounded-lg bg-brand-600 flex items-center justify-center">
            <span class="text-white font-bold">IW</span>
          </div>
          <span class="font-bold text-xl">integraw</span>
        </div>
        <p class="text-brand-100 text-sm leading-relaxed max-w-xs">
          Building high-performance e-commerce stores with PrestaShop and WordPress.
          Based in Kerala, serving clients worldwide.
        </p>
        <p class="mt-4 text-brand-400 text-sm">hello@integraw.in</p>
      </div>

      <div>
        <h4 class="font-semibold text-sm mb-4 text-brand-200 tracking-wide uppercase">Services</h4>
        <ul class="space-y-2 text-sm text-brand-100">
          <li><a href="/services#prestashop" class="hover:text-white transition-colors">PrestaShop</a></li>
          <li><a href="/services#wordpress"  class="hover:text-white transition-colors">WordPress</a></li>
          <li><a href="/services#ecommerce"  class="hover:text-white transition-colors">E-commerce</a></li>
          <li><a href="/services#seo"        class="hover:text-white transition-colors">SEO & Speed</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-sm mb-4 text-brand-200 tracking-wide uppercase">Company</h4>
        <ul class="space-y-2 text-sm text-brand-100">
          <li><a href="/portfolio" class="hover:text-white transition-colors">Portfolio</a></li>
          <li><a href="/blog"      class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/about"     class="hover:text-white transition-colors">About</a></li>
          <li><a href="/contact"   class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-brand-800 max-w-6xl mx-auto px-6 py-5 flex flex-col md:flex-row justify-between items-center gap-2 text-xs text-brand-400">
      <span>© {new Date().getFullYear()} Integraw. All rights reserved.</span>
      <span>Kerala, India · integraw.in</span>
    </div>
  </footer>

  <script>
    const btn  = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  </script>
</body>
</html>
